library(leaflet)
# Dataset
study_sites <- read.csv("study_species.csv", stringsAsFactors=TRUE)
# Named list for colors
project_colors <- list(
"Ongoing" = "darkgreen",
"Field completed, ongoing publications" = "orange",
"Completed" = "yellow"
)
# Build popup HTML
study_sites$popup <- paste0(
"<b>", study_sites$species, "</b><br>",
study_sites$description, "<br>",
"<img src='", study_sites$image_url, "' width='200' style='display:block;margin-top:5px;'>"
)
# Create the leaflet map with alternative tile and global fit
m <- leaflet(study_sites) %>%
# Alternative background map (CartoDB Positron)
addProviderTiles(providers$CartoDB.Positron) %>%
# Add color-coded pins
addCircleMarkers(
lng = ~lon,
lat = ~lat,
color = unlist(lapply(study_sites$project_type, function(x) project_colors[[x]])),
radius = 4,
fillOpacity = 0.8,
popup = ~popup
) %>%
# Legend for project types
addLegend(
"bottomright",
colors = unlist(project_colors),
labels = names(project_colors),
title = "Project Types"
)
# Fit map bounds to show all study sites globally
m %>% fitBounds(
lng1 = min(study_sites$lon) - 10,
lat1 = min(study_sites$lat) - 10,
lng2 = max(study_sites$lon) + 10,
lat2 = max(study_sites$lat) + 10
)
View(study_sites)
