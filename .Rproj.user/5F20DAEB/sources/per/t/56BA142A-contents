---
title: "At-a-Glance"
---

This map displays the locations of our global research projects, along with brief descriptions of the main research questions and study species. Zoom in on the region of the world you are interested in and click on the pins to access individual study projects. For more details, please visit our [Research page]() and [Publication page]().

```{r}
#| echo: false
library(leaflet)

# Dataset
study_sites <- data.frame(
  site = c("Site A", "Site B", "Site C"),
  lat = c(34.05, -33.86, 51.51),
  lon = c(-118.25, 151.21, -0.13),
  species = c("Red Fox", "Common Dolphin", "Pigeon"),
  description = c(
    "Red Fox migration patterns.",
    "Dolphin population dynamics in coastal habitats.",
    "Pigeon behavior in urban environments."
  ),
  image_url = c(
    "Images/1.jpg",
    "Images/2.jpg",
    "Images/3.jpg"
  ),
  project_type = c("Ongoing project", "Completed field, ongoing publications", "Completed project")
)

# Named list for colors
project_colors <- list(
  "Ongoing project" = "darkgreen",
  "Completed field, ongoing publications" = "orange",
  "Completed project" = "yellow"
)

# Build popup HTML
study_sites$popup <- paste0(
  "<b>", study_sites$species, "</b><br>",
  study_sites$description, "<br>",
  "<img src='", study_sites$image_url, "' width='200' style='display:block;margin-top:5px;'>"
)

# Create the leaflet map with alternative tile and global fit
m <- leaflet(study_sites) %>%
  # Alternative background map (CartoDB Positron)
  addProviderTiles(providers$CartoDB.Positron) %>%
  
  # Add color-coded pins
  addCircleMarkers(
    lng = ~lon,
    lat = ~lat,
    color = unlist(lapply(study_sites$project_type, function(x) project_colors[[x]])),
    radius = 4,
    fillOpacity = 0.8,
    popup = ~popup
  ) %>%
  
  # Legend for project types
  addLegend(
    "bottomright",
    colors = unlist(project_colors),
    labels = names(project_colors),
    title = "Project Types"
  )

# Fit map bounds to show all study sites globally
m %>% fitBounds(
  lng1 = min(study_sites$lon) - 10,
  lat1 = min(study_sites$lat) - 10,
  lng2 = max(study_sites$lon) + 10,
  lat2 = max(study_sites$lat) + 10
)


  

```
